{
  "dashboard": {
    "id": null,
    "uid": "openraft-surrealkv",
    "title": "OpenRaft SurrealKV",
    "tags": [
      "openraft",
      "surrealkv"
    ],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "timeseries",
        "title": "Raft Current Term",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "raft_current_term",
            "refId": "A"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "HTTP Requests Total",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "sum by (method, status) (http_requests_total)",
            "refId": "A"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Snapshot Merge Duration (ms)",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "expr": "raft_snapshot_merge_duration_ms",
            "refId": "A"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Storage Keys Total",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "expr": "storage_keys_total",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}

